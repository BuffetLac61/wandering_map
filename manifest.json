{
  "manifest_version": 3,
  "name": "The Marauder's Map",
  "version": "1.0.0",
  "description": "Transforms Incognito browsing into a Marauder's Map parchment experience. Mischief Managed.",
  "icons": {
    "16": "logo.jpg",
    "32": "logo.jpg",
    "48": "logo.jpg",
    "128": "logo.jpg"
  },
  "permissions": ["tabs", "windows", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "all_frames": false,
      "match_about_blank": false
    }
  ],
  "incognito": "spanning"
}
